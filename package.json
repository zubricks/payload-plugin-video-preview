{
  "name": "@zubricks/payload-plugin-video-preview",
  "version": "0.1.0",
  "description": "Payload CMS plugin that auto-generates a preview clip and thumbnail from video uploads",
  "keywords": [
    "payload",
    "payloadcms",
    "plugin",
    "video",
    "ffmpeg",
    "preview",
    "thumbnail"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "author": "Sean Zubrickas <zubricks@gmail.com>",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@vercel/blob": "^0.27.0",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.5",
    "payload": "^3.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "payload": "^3.0.0"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "ffmpeg-static"
    ]
  }
}
